{
    "name": "@dre44/nestjs-kit",
    "version": "0.9.1",
    "description": "Some NestJS utility",
    "main": "dist/index.js",
    "type": "module",
    "exports": {
        ".": "./dist/index.js",
        "./zod": "./dist/zod/index.js",
        "./fastify-multipart": "./dist/fastify-multipart/index.js",
        "./oauth": "./dist/oauth/index.js",
        "./websockets": "./dist/websockets/index.js",
        "./json-rpc": "./dist/json-rpc/index.js",
        "./http-json-rpc": "./dist/http-json-rpc/index.js"
    },
    "scripts": {
        "tc": "tsc --noEmit",
        "tc:watch": "tsc --noEmit --watch",
        "prebuild": "rm -rf dist",
        "build": "tsc"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/andre-hctulc/nestjs-kit.git"
    },
    "keywords": [
        "nestjs",
        "nestjs-kit",
        "nestjs utilities",
        "nestjs utilities kit"
    ],
    "author": "André Thomas",
    "license": "ISC",
    "dependencies": {
        "@nestjs/common": "^11.0.6",
        "cookie": "^1.0.2"
    },
    "devDependencies": {
        "@types/busboy": "^1.5.4",
        "@types/express": "^5.0.1",
        "@types/node": "^22.7.4"
    },
    "peerDependencies": {
        "@fastify/multipart": "^9.0.3",
        "@nestjs/microservices": "^11.1.6",
        "@nestjs/websockets": "^11.1.3",
        "fastify": "^5.4.0",
        "jose": "^6.0.11",
        "openid-client": "^6.5.0",
        "socket.io": "^4.8.1",
        "zod": "^4.1.5",
        "rxjs": "^7.8.2"
    }
