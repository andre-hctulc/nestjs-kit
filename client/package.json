{
    "name": "@dre44/nestjs-kit-client",
    "version": "0.1.0",
    "description": "nestjs-kit Client",
    "type": "module",
    "exports": {
        ".": "./dist/index.js",
        "./websockets-react": "./dist/websockets-react/index.js",
        "./zod": "./dist/zod/index.js"
    },
    "scripts": {
        "tc": "tsc --noEmit",
        "tc:watch": "tsc --noEmit --watch",
        "prebuild": "rm -rf dist",
        "build": "tsup src/index.ts src/zod/index.ts src/websockets-react/index.ts --dts --format esm"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/andre-hctulc/nestjs-kit.git"
    },
    "keywords": [],
    "author": "André Thomas",
    "license": "ISC",
    "devDependencies": {
        "@types/react": "^19.1.8",
        "tsup": "^8.5.0",
        "typescript": "^5.8.3"
    },
    "peerDependencies": {
        "react": "^19.1.0",
        "socket.io-client": "^4.8.1",
        "zod": "^3.25.67"
    }
}
